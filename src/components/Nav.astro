---
interface Props {
  activePage: string;
}

const { activePage } = Astro.props;

const navItems = [
  { label: 'Início', href: '/' },
  { label: 'Benefícios', href: '/beneficios' },
  { label: 'Acervo estudantil', href: '/acervo' },
  { label: 'Livros', href: '/livros' },
  { label: 'Entre em contato', href: '/contato' },
];
---
<header class="w-full border-b border-[#1a1a1a]">
  <nav class="max-w-5xl mx-auto px-6 py-4 flex items-center justify-between gap-4">
    <a href="/" class="font-logo text-2xl italic text-white tracking-tight">
      studentshub
    </a>
    <div class="flex items-center gap-1 border border-[#2a2a2a] rounded-full px-1.5 py-1.5">
      {navItems.map(item => (
        <a
          href={item.href}
          class={[
            'px-3.5 py-1.5 rounded-full text-sm font-medium transition-colors whitespace-nowrap',
            activePage === item.href
              ? 'bg-white text-black'
              : 'text-[#999] hover:text-white',
          ].join(' ')}
        >
          {item.label}
        </a>
      ))}
    </div>
  </nav>
</header>
