---
interface Props {
  activePage: string;
}

const { activePage } = Astro.props;

const navItems = [
  { label: 'Início', href: '/' },
  { label: 'Benefícios', href: '/beneficios' },
  { label: 'Acervo estudantil', href: '/acervo' },
  { label: 'Livros', href: '/livros' },
  { label: 'Entre em contato', href: '/contato' },
];
---
<header class="w-full border-b border-[#1a1a1a]">
  <nav class="max-w-5xl mx-auto px-6 py-4 flex items-center justify-between gap-4">
    <a href="/" class="font-logo text-3xl italic text-white tracking-tight leading-none">
      studentshub
    </a>
    <div class="nav-pill-container flex items-center gap-1 rounded-full px-1.5 py-1.5">
      {navItems.map(item => (
        <a
          href={item.href}
          class={[
            'px-4 py-2 rounded-full text-sm whitespace-nowrap transition-colors',
            activePage === item.href
              ? 'nav-link-active font-medium text-white'
              : 'font-normal text-[#777] hover:text-white',
          ].join(' ')}
        >
          {item.label}
        </a>
      ))}
    </div>
  </nav>
</header>

<style>
  .nav-pill-container {
    background: linear-gradient(to bottom, #131313, #0d0d0d);
    box-shadow:
      inset 0 2px 5px rgba(0, 0, 0, 0.7),
      inset 0 1px 2px rgba(0, 0, 0, 0.5),
      0 1px 0 rgba(255, 255, 255, 0.03);
    border: 1px solid #1e1e1e;
  }

  .nav-link-active {
    background: linear-gradient(160deg, #363636 0%, #252525 100%);
    border: 1px solid #404040;
    border-bottom-color: #323232;
    box-shadow:
      0 4px 10px rgba(0, 0, 0, 0.7),
      0 2px 4px rgba(0, 0, 0, 0.5),
      inset 0 1px 0 rgba(255, 255, 255, 0.09),
      inset 0 -1px 0 rgba(0, 0, 0, 0.2);
  }
</style>
