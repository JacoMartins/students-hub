---
const navItems = [
  { label: 'Início', href: '/' },
  { label: 'Benefícios', href: '/beneficios' },
  { label: 'Acervo estudantil', href: '/acervo' },
  { label: 'Livros', href: '/livros' },
  { label: 'Entre em contato', href: '/contato' },
];
---
<footer class="border-t border-[#1a1a1a] mt-16">
  <div class="max-w-5xl mx-auto px-6 py-10 flex justify-between items-start gap-8">
    <div>
      <a href="/" class="font-logo text-xl italic text-white tracking-tight">studentshub</a>
      <p class="text-sm text-[#666] mt-2">De estudantes, para os estudantes.</p>
    </div>
    <div class="text-right">
      <p class="text-sm font-medium text-[#888] mb-3">Links Rápidos</p>
      <ul class="flex flex-col gap-1.5">
        {navItems.map(item => (
          <li>
            <a href={item.href} class="text-sm text-[#777] hover:text-white transition-colors">
              {item.label}
            </a>
          </li>
        ))}
      </ul>
    </div>
  </div>
  <div class="border-t border-[#1a1a1a] py-4 text-center">
    <p class="text-xs text-[#555]">
      {new Date().getFullYear()}, Desenvolvido pela comunidade dos alunos do IFCE.
    </p>
  </div>
</footer>
